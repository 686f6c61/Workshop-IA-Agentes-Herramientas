    &nbsp;&nbsp;model: <span class="string">"claude-sonnet-4-6"</span>,<br/>
    &nbsp;&nbsp;messages: [&#123; role: <span class="string">"user"</span>, content: [<br/>
    &nbsp;&nbsp;&nbsp;&nbsp;&#123; type: <span class="string">"image"</span>, source: &#123;<br/>
    &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;type: <span class="string">"url"</span>,<br/>
    &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;url: <span class="string">"https://ejemplo.com/screenshot.png"</span><br/>
    &nbsp;&nbsp;&nbsp;&nbsp;&#125; &#125;,<br/>
    &nbsp;&nbsp;&nbsp;&nbsp;&#123; type: <span class="string">"text"</span>,<br/>
    &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;text: <span class="string">"¿Qué error muestra esta captura?"</span> &#125;<br/>
    &nbsp;&nbsp;] &#125;]<br/>
    &#125;);
