---

<Layout title="Workshop de IA: agentes, modelos y herramientas - by 686f6c61">
  <!-- TABLE OF CONTENTS OVERLAY -->
  <div class="toc-overlay" id="toc">
    <div class="toc-content">
      <div class="toc-header">
        <h2>Índice</h2>
        <button class="toc-close" id="toc-close" aria-label="Cerrar índice">&times;</button>
      </div>
      {tocSections.map((section) => (
        <div class="toc-section">
          <button class="toc-section-title" data-goto={section.sectionSlide}>{section.title}</button>
          {section.items.map((item) => (
            <button class="toc-item" data-goto={item.id}>
              <span class="toc-num">{String(item.num).padStart(2, '0')}</span>
              {item.label}
            </button>
          ))}
        </div>
      ))}
    </div>
  </div>

  <!-- SLIDES -->
  <div class="slides-container" id="slides-container">
    <SlidesIntro />
    <SlidesModelos />
    <SlidesAgentes />
    <SlidesOllamaCloud />
  </div>

  <!-- NAVIGATION BAR -->
  <nav class="nav-bar">
    <div class="nav-buttons">
      <button class="nav-btn" id="prev-btn" aria-label="Slide anterior">&#8592;</button>
      <span class="nav-counter" id="nav-counter">0 / 0</span>
      <button class="nav-btn" id="next-btn" aria-label="Slide siguiente">&#8594;</button>
    </div>
    <div class="nav-progress">
      <div class="nav-progress-bar" id="progress-bar"></div>
    </div>
    <button class="nav-toc-btn" id="toc-btn">Índice</button>
    <div class="nav-keys">
      <kbd id="kbd-prev" role="button" tabindex="0" style="cursor:pointer;">&#8592;</kbd><kbd id="kbd-next" role="button" tabindex="0" style="cursor:pointer;">&#8594;</kbd>
    </div>
  </nav>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const slides = /** @type {NodeListOf<HTMLElement>} */ (document.querySelectorAll('.slide'));
      const counter = document.getElementById('nav-counter');
      const progressBar = document.getElementById('progress-bar');
      const prevBtn = document.getElementById('prev-btn');
      const nextBtn = document.getElementById('next-btn');
      const tocOverlay = document.getElementById('toc');
      const tocBtn = document.getElementById('toc-btn');
      const tocClose = document.getElementById('toc-close');
      const tocItems = /** @type {NodeListOf<HTMLElement>} */ (document.querySelectorAll('.toc-item, .toc-section-title'));

      let current = 0;
      const total = slides.length;
      let numberBuffer = '';
      let numberTimer = null;

      function showSlide(index) {
        if (index < 0 || index >= total) return;
        slides[current].classList.remove('active');
        current = index;
        slides[current].classList.add('active');
        slides[current].scrollTop = 0;
        updateUI();
        const id = slides[current].id;
        history.replaceState(null, '', `#${id}`);
      }

      function updateUI() {
        counter.textContent = `${current} / ${total - 1}`;
        const progress = total > 1 ? (current / (total - 1)) * 100 : 0;
        progressBar.style.width = `${progress}%`;
        prevBtn.disabled = current === 0;
        nextBtn.disabled = current === total - 1;
      }

      function next() { showSlide(current + 1); }
      function prev() { showSlide(current - 1); }

      function goToSlide(id) {
        const index = Array.from(slides).findIndex(s => s.id === id);
        if (index !== -1) {
          showSlide(index);
          closeToc();
        }
      }

      function openToc() { tocOverlay.classList.add('active'); }
      function closeToc() { tocOverlay.classList.remove('active'); }

      prevBtn.addEventListener('click', prev);
      nextBtn.addEventListener('click', next);
      tocBtn.addEventListener('click', openToc);
      tocClose.addEventListener('click', closeToc);

      const kbdPrev = document.getElementById('kbd-prev');
      const kbdNext = document.getElementById('kbd-next');
      if (kbdPrev) kbdPrev.addEventListener('click', prev);
      if (kbdNext) kbdNext.addEventListener('click', next);

      tocOverlay.addEventListener('click', (e) => {
        if (e.target === tocOverlay) closeToc();
      });

      tocItems.forEach(item => {
        item.addEventListener('click', () => {
          const id = item.dataset.goto;
          if (id) goToSlide(id);
        });
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') { closeToc(); return; }
        if (tocOverlay.classList.contains('active')) return;

        if (e.key === 'ArrowRight' || e.key === 'ArrowDown' || e.key === ' ') {
          e.preventDefault(); next();
        } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
          e.preventDefault(); prev();
        } else if (e.key === 'Home') {
          e.preventDefault(); showSlide(0);
        } else if (e.key === 'End') {
          e.preventDefault(); showSlide(total - 1);
        } else if (e.key >= '0' && e.key <= '9') {
          numberBuffer += e.key;
          clearTimeout(numberTimer);
          numberTimer = setTimeout(() => {
            const num = parseInt(numberBuffer, 10);
            if (num >= 0 && num < total) showSlide(num);
            numberBuffer = '';
          }, 500);
        }
      });

      // Touch/swipe support
      let touchStartX = 0;
      let touchStartY = 0;

      document.addEventListener('touchstart', (e) => {
        touchStartX = e.touches[0].clientX;
        touchStartY = e.touches[0].clientY;
      }, { passive: true });

      document.addEventListener('touchend', (e) => {
        const deltaX = e.changedTouches[0].clientX - touchStartX;
        const deltaY = e.changedTouches[0].clientY - touchStartY;
        if (Math.abs(deltaX) > Math.abs(deltaY) && Math.abs(deltaX) > 50) {
          if (deltaX < 0) next(); else prev();
        }
      }, { passive: true });

      // Initial slide from hash
      const hash = window.location.hash.slice(1);
      if (hash) {
        const index = Array.from(slides).findIndex(s => s.id === hash);
        if (index !== -1) current = index;
      }
      slides[current].classList.add('active');
      updateUI();
    });
  </script>
</Layout>
